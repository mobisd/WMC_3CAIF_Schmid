# Copy this file to .env and fill in real values. NEVER commit your real .env.

# Flask session signing key. Generate a strong random value, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# TMDB v3 API key. Get a free one at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your-tmdb-api-key

# Optional overrides -----------------------------------------------------------
# DATABASE_URI=sqlite:///instance/app.db

# Set to 1 only when serving over HTTPS (production). Leave 0 for localhost.
# SESSION_COOKIE_SECURE=0

# Set to 0 after you have built static/css/output.css with the Tailwind CLI.
# When 1 (default), base.html loads the Tailwind Play CDN for dev convenience.
# TAILWIND_CDN=1
